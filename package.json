{
  "name": "naturheilpraxis",
  "version": "0.1.0",
  "description": "Mit dieser App können Heilpraktiker Leistungen für Patienten erfassen, um ihnen diese in Rechnung stellen zu können.",
  "keywords": [
    "naturheilpraxis",
    "heilpraktiker",
    "rechnung"
  ],
  "author": "Falko Schumann",
  "homepage": "https://github.com/falkoschumann/naturheilpraxis",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/falkoschumann/naturheilpraxis/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/falkoschumann/naturheilpraxis.git"
  },
  "engines": {
    "bun": ">=1.2.0",
    "node": ">=24.0.0"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "test": "vitest run",
    "watch": "vitest watch",
    "start": "electron-vite preview",
    "dev": "electron-vite dev --watch",
    "build": "tsc --build && electron-vite build",
    "build:unpack": "electron-builder --dir",
    "build:electron": "electron-builder",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac --arm64",
    "build:linux": "electron-builder --linux --x64",
    "postinstall": "electron-builder install-app-deps"
  },
  "devDependencies": {
    "@eslint/js": "9.39.3",
    "@js-temporal/polyfill": "0.5.1",
    "@muspellheim/shared": "0.18.1",
    "@softarc/sheriff-core": "0.19.6",
    "@tanstack/react-table": "8.21.3",
    "@tanstack/react-virtual": "3.13.23",
    "@types/node": "24.12.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "@vitest/coverage-istanbul": "4.1.0",
    "bootstrap": "5.3.8",
    "bootstrap-icons": "1.13.1",
    "bootstrap5-tags": "1.7.16",
    "electron": "41.0.3",
    "electron-builder": "26.8.1",
    "electron-devtools-installer": "4.0.0",
    "electron-vite": "5.0.0",
    "eslint": "9.39.3",
    "eslint-plugin-headers": "1.3.3",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "flux-standard-action": "2.1.2",
    "globals": "17.4.0",
    "prettier": "3.8.1",
    "prettier-plugin-sql": "0.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router": "7.13.1",
    "sass": "1.98.0",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.1",
    "vite": "7.3.1",
    "vitest": "4.1.0"
  }
}
